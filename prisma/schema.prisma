generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Validator {
  id                String              @id // operatorAddress
  moniker           String
  status            String
  tokens            String
  commission        Float
  jailed            Boolean             @default(false)
  uptime            Float               @default(0)
  votingPower       String
  missedBlocks      Int                 @default(0)
  jailCount         Int                 @default(0)
  lastJailedAt      DateTime?
  consensusPubkey    String?
  consensusAddress   String?
  commissionRewards  String              @default("0")
  outstandingRewards String              @default("0")
  firstSeen          DateTime            @default(now())
  lastUpdated       DateTime            @updatedAt
  snapshots         ValidatorSnapshot[]
  scores            ValidatorScore[]
  delegationSnapshots DelegationSnapshot[]

  @@index([status])
  @@index([jailed])
  @@index([consensusAddress])
}

model ValidatorSnapshot {
  id          String    @id @default(cuid())
  validatorId String
  validator   Validator @relation(fields: [validatorId], references: [id], onDelete: Cascade)
  tokens      String
  status      String
  commission  Float
  jailed      Boolean
  votingPower String
  timestamp   DateTime  @default(now())

  @@index([validatorId, timestamp])
  @@index([timestamp])
}

model Endpoint {
  id           String           @id @default(cuid())
  url          String           @unique
  type         String
  provider     String?
  isOfficial   Boolean          @default(false)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  healthChecks EndpointHealth[]
  scores       EndpointScore[]

  @@index([type])
  @@index([isActive])
}

model EndpointHealth {
  id          String   @id @default(cuid())
  endpointId  String
  endpoint    Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  latencyMs   Int
  statusCode  Int
  isHealthy   Boolean
  blockHeight BigInt?
  error       String?
  timestamp   DateTime @default(now())

  @@index([endpointId, timestamp])
  @@index([timestamp])
}

model NetworkStats {
  id                  String   @id @default(cuid())
  totalValidators     Int
  activeValidators    Int
  totalStaked         String
  bondedRatio         Float?
  blockHeight         BigInt
  avgBlockTime        Float?
  inflation           Float?
  totalSupply         String?
  bondedTokens        String?
  notBondedTokens     String?
  stakingAPR          Float?
  nakamotoCoefficient Int?
  networkHealthScore  Float?
  timestamp           DateTime @default(now())

  @@index([timestamp])
}

model EndpointScore {
  id         String   @id @default(cuid())
  endpointId String
  endpoint   Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  score      Float
  uptime     Float
  latency    Float
  freshness  Float
  errorRate  Float
  timestamp  DateTime @default(now())

  @@index([endpointId, timestamp])
  @@index([timestamp])
}

model ValidatorScore {
  id              String    @id @default(cuid())
  validatorId     String
  validator       Validator @relation(fields: [validatorId], references: [id], onDelete: Cascade)
  score           Float
  missedBlockRate Float
  jailPenalty     Float
  stakeStability  Float
  commissionScore Float
  governanceScore Float     @default(0)
  timestamp       DateTime  @default(now())

  @@index([validatorId, timestamp])
  @@index([timestamp])
}

model Anomaly {
  id          String    @id @default(cuid())
  type        String
  severity    String
  entityType  String
  entityId    String?
  title       String
  description String
  metadata    String?
  resolved    Boolean   @default(false)
  detectedAt  DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([type])
  @@index([severity])
  @@index([detectedAt])
  @@index([resolved])
  @@index([type, entityId, resolved])
}

model Workspace {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  adminTokenHash String?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  webhooks       Webhook[]
  slos           Slo[]
  incidents      Incident[]
  policies       Policy[]
  apiKeys        ApiKey[]
  members        WorkspaceMember[]
  auditLogs      AuditLog[]

  @@index([slug])
}

model User {
  id        String            @id @default(cuid())
  address   String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  sessions  UserSession[]
  members   WorkspaceMember[]
  auditLogs AuditLog[]

  @@index([address])
}

model AuditLog {
  id           String    @id @default(cuid())
  workspaceId  String
  actorUserId  String?
  actorAddress String
  action       String
  resourceType String
  resourceId   String?
  metadata     String?
  createdAt    DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor        User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  nonce     String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String    @default("viewer")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Webhook {
  id              String            @id @default(cuid())
  workspaceId     String
  workspace       Workspace         @relation(fields: [workspaceId], references: [id])
  name            String
  url             String
  secretEncrypted String
  events          String[]
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deliveries      WebhookDelivery[]

  @@index([workspaceId])
  @@index([isActive])
}

model WebhookDelivery {
  id            String    @id @default(cuid())
  webhookId     String
  webhook       Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  outboxEventId String
  eventType     String
  payload       String
  statusCode    Int?
  responseBody  String?
  success       Boolean   @default(false)
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  nextRetryAt   DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime  @default(now())

  @@unique([webhookId, outboxEventId])
  @@index([webhookId, createdAt])
  @@index([success, nextRetryAt])
}

model OutboxEvent {
  id          String   @id @default(cuid())
  seq         Int      @default(autoincrement())
  channel     String
  type        String
  visibility  String   @default("public")
  workspaceId String?
  payload     String
  createdAt   DateTime @default(now())

  @@index([seq])
  @@index([channel, seq])
  @@index([workspaceId, seq])
}

model WebhookCursor {
  id        String   @id @default("singleton")
  lastSeq   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Slo {
  id              String          @id @default(cuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id])
  name            String
  indicator       String
  entityType      String
  entityId        String
  target          Float
  windowDays      Int
  isActive        Boolean         @default(true)
  isBreaching     Boolean         @default(false)
  currentValue    Float?
  budgetConsumed  Float?
  burnRate        Float?
  lastEvaluatedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  evaluations     SloEvaluation[]

  @@index([workspaceId])
  @@index([isActive])
  @@index([entityType, entityId])
}

model SloEvaluation {
  id              String   @id @default(cuid())
  sloId           String
  slo             Slo      @relation(fields: [sloId], references: [id], onDelete: Cascade)
  sliValue        Float
  budgetConsumed  Float
  budgetRemaining Float
  burnRate        Float
  isBreaching     Boolean
  evaluatedAt     DateTime @default(now())

  @@index([sloId, evaluatedAt])
  @@index([evaluatedAt])
}

model Incident {
  id              String          @id @default(cuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id])
  entityType      String
  entityId        String
  status          String          @default("open")
  severity        String
  title           String
  description     String
  detectedAt      DateTime        @default(now())
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  events          IncidentEvent[]

  @@index([workspaceId, status])
  @@index([workspaceId, entityType, entityId])
  @@index([status, detectedAt])
  @@index([detectedAt])
}

model IncidentEvent {
  id          String   @id @default(cuid())
  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  eventType   String
  message     String
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([incidentId, createdAt])
  @@index([createdAt])
}

model Policy {
  id              String            @id @default(cuid())
  workspaceId     String
  workspace       Workspace         @relation(fields: [workspaceId], references: [id])
  name            String
  description     String?
  isActive        Boolean           @default(true)
  dryRun          Boolean           @default(true)
  priority        Int               @default(100)
  conditions      String
  actions         String
  cooldownMinutes Int               @default(15)
  lastTriggeredAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  executions      PolicyExecution[]

  @@index([workspaceId])
  @@index([isActive, priority])
}

model PolicyExecution {
  id              String   @id @default(cuid())
  policyId        String
  policy          Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  triggerEntity   String
  conditionsMet   String
  actionsTaken    String
  actionsResults  String
  dryRun          Boolean  @default(false)
  timestamp       DateTime @default(now())

  @@index([policyId, timestamp])
}

model ActionRecord {
  id            String    @id @default(cuid())
  workspaceId   String
  policyId      String?
  actionType    String
  entityType    String
  entityId      String
  rollbackData  String?
  appliedAt     DateTime  @default(now())
  expiresAt     DateTime
  rolledBackAt  DateTime?

  @@index([workspaceId, appliedAt])
  @@index([expiresAt, rolledBackAt])
  @@index([entityType, entityId])
}

model GovernanceProposal {
  id              String            @id
  title           String
  description     String?
  status          String
  proposer        String?
  submitTime      DateTime?
  votingStartTime DateTime?
  votingEndTime   DateTime?
  yesVotes        String            @default("0")
  noVotes         String            @default("0")
  abstainVotes    String            @default("0")
  vetoVotes       String            @default("0")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  votes           GovernanceVote[]

  @@index([status])
  @@index([votingEndTime])
}

model GovernanceVote {
  id         String             @id @default(cuid())
  proposalId String
  proposal   GovernanceProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voter      String
  option     String
  votedAt    DateTime?
  createdAt  DateTime           @default(now())

  @@unique([proposalId, voter])
  @@index([voter])
}

model DelegationEvent {
  id            String   @id @default(cuid())
  type          String
  delegator     String
  validatorFrom String?
  validatorTo   String
  amount        String
  txHash        String?
  blockHeight   String?
  timestamp     DateTime @default(now())

  @@index([validatorTo, timestamp])
  @@index([validatorFrom, timestamp])
  @@index([delegator])
  @@index([type, timestamp])
}

model DelegationSnapshot {
  id             String   @id @default(cuid())
  validatorId    String
  validator      Validator @relation(fields: [validatorId], references: [id], onDelete: Cascade)
  totalDelegators Int
  totalDelegated  String
  topDelegators   String
  churnRate       Float
  timestamp       DateTime @default(now())

  @@index([validatorId, timestamp])
}

model Forecast {
  id             String    @id @default(cuid())
  entityType     String
  entityId       String
  metric         String
  prediction     String
  confidence     Float
  timeHorizon    String
  currentValue   Float
  predictedValue Float
  threshold      Float?
  reasoning      String
  validUntil     DateTime
  actualValue    Float?
  wasAccurate    Boolean?
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([metric])
  @@index([validUntil])
  @@index([createdAt])
  @@index([entityType, entityId, validUntil])
}

model ApiKey {
  id            String              @id @default(cuid())
  workspaceId   String
  workspace     Workspace           @relation(fields: [workspaceId], references: [id])
  name          String
  keyHash       String              @unique
  keyPrefix     String
  tier          String              @default("free")
  isActive      Boolean             @default(true)
  rateLimit     Int                 @default(60)
  dailyQuota    Int                 @default(1000)
  monthlyQuota  Int                 @default(10000)
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime            @default(now())
  usageCounters ApiKeyUsageCounter[]

  @@index([workspaceId])
  @@index([keyHash])
}

model ApiKeyUsageCounter {
  id         String   @id @default(cuid())
  apiKeyId   String
  apiKey     ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  period     String
  periodType String
  count      Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([apiKeyId, period, periodType])
  @@index([apiKeyId])
}
