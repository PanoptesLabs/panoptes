generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Validator {
  id               String              @id // operatorAddress
  moniker          String
  status           String
  tokens           String
  commission       Float
  jailed           Boolean             @default(false)
  uptime           Float               @default(0)
  votingPower      String
  missedBlocks     Int                 @default(0)
  jailCount        Int                 @default(0)
  lastJailedAt     DateTime?
  firstSeen        DateTime            @default(now())
  lastUpdated      DateTime            @updatedAt
  snapshots        ValidatorSnapshot[]
  scores           ValidatorScore[]

  @@index([status])
  @@index([jailed])
}

model ValidatorSnapshot {
  id          String    @id @default(cuid())
  validatorId String
  validator   Validator @relation(fields: [validatorId], references: [id], onDelete: Cascade)
  tokens      String
  status      String
  commission  Float
  jailed      Boolean
  votingPower String
  timestamp   DateTime  @default(now())

  @@index([validatorId, timestamp])
  @@index([timestamp])
}

model Endpoint {
  id           String           @id @default(cuid())
  url          String           @unique
  type         String
  provider     String?
  isOfficial   Boolean          @default(false)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  healthChecks EndpointHealth[]
  scores       EndpointScore[]

  @@index([type])
  @@index([isActive])
}

model EndpointHealth {
  id          String   @id @default(cuid())
  endpointId  String
  endpoint    Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  latencyMs   Int
  statusCode  Int
  isHealthy   Boolean
  blockHeight BigInt?
  error       String?
  timestamp   DateTime @default(now())

  @@index([endpointId, timestamp])
  @@index([timestamp])
}

model NetworkStats {
  id               String   @id @default(cuid())
  totalValidators  Int
  activeValidators Int
  totalStaked      String
  bondedRatio      Float?
  blockHeight      BigInt
  avgBlockTime     Float?
  timestamp        DateTime @default(now())

  @@index([timestamp])
}

model EndpointScore {
  id         String   @id @default(cuid())
  endpointId String
  endpoint   Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  score      Float
  uptime     Float
  latency    Float
  freshness  Float
  errorRate  Float
  timestamp  DateTime @default(now())

  @@index([endpointId, timestamp])
  @@index([timestamp])
}

model ValidatorScore {
  id              String    @id @default(cuid())
  validatorId     String
  validator       Validator @relation(fields: [validatorId], references: [id], onDelete: Cascade)
  score           Float
  missedBlockRate Float
  jailPenalty     Float
  stakeStability  Float
  commissionScore Float
  timestamp       DateTime  @default(now())

  @@index([validatorId, timestamp])
  @@index([timestamp])
}

model Anomaly {
  id          String    @id @default(cuid())
  type        String
  severity    String
  entityType  String
  entityId    String?
  title       String
  description String
  metadata    String?
  resolved    Boolean   @default(false)
  detectedAt  DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([type])
  @@index([severity])
  @@index([detectedAt])
  @@index([resolved])
}

model Workspace {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  adminTokenHash String   @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
}
