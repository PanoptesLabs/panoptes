# ── Database (PostgreSQL + PgBouncer) ──────────────────────────
# Pooled connection via PgBouncer — used by the application at runtime
# SSL is configured in application code (ssl: { rejectUnauthorized: false })
DATABASE_URL="postgresql://panoptes:pass@your-db-host:6432/panoptes?pgbouncer=true"
# Direct connection — used only for Prisma migrations
DIRECT_URL="postgresql://panoptes:pass@your-db-host:5432/panoptes"

# ── Republic Chain ─────────────────────────────────────────────
REPUBLIC_RPC_URL="https://rpc.republicai.io"
REPUBLIC_REST_URL="https://rest.republicai.io"

# ── Cron Security ──────────────────────────────────────────────
# Bearer token for cron job authentication (GitHub Actions → API)
# Generate with: openssl rand -hex 32
CRON_SECRET="change-me-to-a-strong-random-string"

# ── Cron Control ───────────────────────────────────────────────
# Set to "true" in GitHub Actions to enable scheduled cron jobs
CRONS_ENABLED="false"

# ── Admin Addresses ──────────────────────────────────────────
# Comma-separated list of wallet addresses that get admin role on login
PANOPTES_ADMIN_ADDRESSES="rai1..."

# ── Webhook Security ─────────────────────────────────────────
# AES-256-GCM encryption key for webhook signing secrets
# Generate with: openssl rand -hex 32
WEBHOOK_ENCRYPTION_KEY="change-me-to-a-64-char-hex-string"

# ── Stream Token ────────────────────────────────────────────
# HMAC-SHA256 secret for signing SSE stream tokens
# Generate with: openssl rand -hex 32
STREAM_TOKEN_SECRET="change-me-to-a-strong-random-string"

# ── Application ────────────────────────────────────────────────
# Public URL (used for CORS, sitemap, OG images)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Dashboard URL (used for CTA links and middleware routing)
NEXT_PUBLIC_DASHBOARD_URL="http://localhost:3000"
NODE_ENV="development"
